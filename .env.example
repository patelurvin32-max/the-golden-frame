# ── Docker compose environment ────────────────────────────────────────────────
# Copy this to .env and fill in real values before deploying

# MongoDB root credentials (container bootstrap)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=cuemaster2024

# JWT — use a long random string (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=REPLACE_ME_STRONG_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_ME_STRONG_REFRESH_SECRET

# Public URL of your deployment
CLIENT_URL=http://localhost

# First-run super admin credentials (change immediately after first login)
SUPER_ADMIN_EMAIL=admin@cuemaster.app
SUPER_ADMIN_PASSWORD=Admin@123456

# Cloudinary (optional — for avatar/image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Automation
EMAIL_PROVIDER=brevo-api
BREVO_API_KEY=
BREVO_FROM_EMAIL=The Golden Frame <reports@yourverifieddomain.com>
BREVO_FROM_NAME=The Golden Frame
REPORT_TIMEZONE=Asia/Kolkata
DAILY_REPORT_SCHEDULER_SECRET=REPLACE_ME_SCHEDULER_SECRET
DAILY_REPORT_RECIPIENT_EMAILS=client@example.com
DAILY_REPORT_BRANCH_IDS=
# Optional Brevo SMTP fallback
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_SECURE=false
